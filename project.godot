; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Eclipse Frontier"
config/version="0.1.0"
config/description="An open world survival and building game"
config/tags=PackedStringArray("game", "android", "survival", "building")
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://assets/sprites/ui/icon.png"
boot_splash/image="res://assets/ui/boot_splash.png"
boot_splash/bg_color=Color(0.1, 0.1, 0.15, 1)

[audio]

buses/default_bus_layout="res://assets/audio/default_bus_layout.tres"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/per_pixel_transparency/allowed=false

[editor_plugins]

enabled=PackedStringArray()

[filesystem]

import/blender/enabled=false

